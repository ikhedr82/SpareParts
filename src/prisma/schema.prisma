generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("USD")
  billingCycle  BillingCycle   @default(MONTHLY) @map("billing_cycle")
  isActive      Boolean        @default(true) @map("is_active")
  features      Json?          @default("{}")
  limits        Json?          @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  nameAr        String?        @map("name_ar")
  subscriptions Subscription[]
  tenants       Tenant[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique @map("tenant_id")
  planId               String             @map("plan_id")
  status               SubscriptionStatus @default(TRIAL)
  billingCycle         BillingCycle       @default(MONTHLY) @map("billing_cycle")
  startDate            DateTime           @default(now()) @map("start_date")
  endDate              DateTime?          @map("end_date")
  trialEndDate         DateTime?          @map("trial_end_date")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  provider             String             @default("STRIPE")
  billingInvoices      BillingInvoice[]
  plan                 Plan               @relation(fields: [planId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

model UsageMetric {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  metricType String   @map("metric_type")
  value      Int
  timestamp  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, metricType, timestamp])
  @@map("usage_metrics")
}

model BillingInvoice {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  subscriptionId  String?       @map("subscription_id")
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime      @map("due_date")
  paidAt          DateTime?     @map("paid_at")
  stripeInvoiceId String?       @map("stripe_invoice_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@map("billing_invoices")
}

model BillingEvent {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  type      BillingEventType
  metadata  Json?            @default("{}")
  timestamp DateTime         @default(now())
  tenant    Tenant           @relation(fields: [tenantId], references: [id])

  @@map("billing_events")
}

model Currency {
  code              String         @id
  name              String
  symbol            String
  isActive          Boolean        @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  precision         Int            @default(2)
  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")

  @@map("currencies")
}

model ExchangeRate {
  id              String   @id @default(uuid())
  fromCurrency    String   @map("from_currency")
  toCurrency      String   @map("to_currency")
  rate            Decimal  @db.Decimal(18, 6)
  updatedAt       DateTime @updatedAt @map("updated_at")
  effectiveAt     DateTime @default(now()) @map("effective_at")
  source          String?  @default("Manual")
  fromCurrencyRef Currency @relation("FromCurrency", fields: [fromCurrency], references: [code])
  toCurrencyRef   Currency @relation("ToCurrency", fields: [toCurrency], references: [code])

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

model Tenant {
  id                    String                 @id @default(uuid())
  name                  String
  subdomain             String                 @unique
  status                String                 @default("ACTIVE")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  defaultLanguage       LanguageCode           @default(EN) @map("default_language")
  supportedLanguages    LanguageCode[]         @default([EN, AR]) @map("supported_languages")
  suspensionReason      String?                @map("suspension_reason")
  baseCurrency          String                 @default("USD") @map("base_currency")
  planId                String?                @map("plan_id")
  supportedCurrencies   String[]               @default(["USD"]) @map("supported_currencies")
  billingEmail          String?                @map("billing_email")
  stripeCustomerId      String?                @map("stripe_customer_id")
  accountingEvents      AccountingEvent[]
  accountingPeriods     AccountingPeriod[]
  auditLogs             AuditLog[]
  billingEvents         BillingEvent[]
  billingInvoices       BillingInvoice[]
  branchTransfers       BranchTransfer[]
  branches              Branch[]
  businessClients       BusinessClient[]
  carts                 Cart[]
  cashSessions          CashSession[]
  chargebackResolutions ChargebackResolution[]
  chargebacks           Chargeback[]
  chartOfAccounts       ChartOfAccount[]
  customers             Customer[]
  deliveryExceptions    DeliveryException[]
  deliveryTrips         DeliveryTrip[]
  drivers               Driver[]
  fulfillmentProviders  FulfillmentProvider[]
  idempotencyRecords    IdempotencyRecord[]
  inventory             Inventory[]
  inventoryLedger       InventoryLedger[]
  invoices              Invoice[]
  journalEntries        JournalEntry[]
  orders                Order[]
  outboxEvents          OutboxEvent[]
  payments              Payment[]
  pickLists             PickList[]
  priceRules            PriceRule[]
  purchaseOrders        PurchaseOrder[]
  purchaseReturns       PurchaseReturn[]
  quotes                Quote[]
  receipts              Receipt[]
  refunds               Refund[]
  returnToWarehouses    ReturnToWarehouse[]
  returns               Return[]
  revenueLedgers        RevenueLedger[]
  roles                 Role[]
  sales                 Sale[]
  shipmentManifests     ShipmentManifest[]
  shortageSubstitutions ShortageSubstitution[]
  stripePayments        StripePayment[]
  subscription          Subscription?
  substitutions         Substitution[]
  supplierInvoices      SupplierInvoice[]
  suppliers             Supplier[]
  supportTickets        SupportTicket[]
  taxFilings            TaxFiling[]
  taxRates              TaxRate[]
  plan                  Plan?                  @relation(fields: [planId], references: [id])
  usageMetrics          UsageMetric[]
  userRoles             UserRole[]
  users                 User[]
  vehicles              Vehicle[]
  zReports              ZReport[]

  @@map("tenants")
}

model User {
  id                     String              @id @default(uuid())
  tenantId               String?             @map("tenant_id")
  email                  String              @unique
  passwordHash           String              @map("password_hash")
  isPlatformUser         Boolean             @default(false) @map("is_platform_user")
  status                 String              @default("ACTIVE")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version                Int                 @default(0)
  closedPeriods          AccountingPeriod[]  @relation("ClosedBy")
  auditLogs              AuditLog[]
  closedSessions         CashSession[]       @relation("ClosedBy")
  openedSessions         CashSession[]       @relation("OpenedBy")
  idempotencyRecords     IdempotencyRecord[]
  inventoryLedgerEntries InventoryLedger[]
  createdJournalEntries  JournalEntry[]      @relation("CreatedBy")
  postedJournalEntries   JournalEntry[]      @relation("PostedBy")
  pickAssignments        PickList[]          @relation("PickAssignments")
  createdPurchaseOrders  PurchaseOrder[]
  purchaseReturns        PurchaseReturn[]
  cancelledRefunds       Refund[]            @relation("RefundCancelledBy")
  refunds                Refund[]
  processedRefunds       Refund[]            @relation("RefundProcessedBy")
  userRoles              UserRole[]
  tenant                 Tenant?             @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Role {
  id            String           @id @default(uuid())
  tenantId      String?          @map("tenant_id")
  name          String
  scope         RoleScope
  description   String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version       Int              @default(0)
  descriptionAr String?          @map("description_ar")
  nameAr        String?          @map("name_ar")
  permissions   RolePermission[]
  tenant        Tenant?          @relation(fields: [tenantId], references: [id])
  userRoles     UserRole[]

  @@unique([tenantId, name, scope])
  @@map("roles")
}

model Permission {
  id            String           @id @default(uuid())
  code          String           @unique
  description   String?
  descriptionAr String?          @map("description_ar")
  roles         RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  roleId   String  @map("role_id")
  tenantId String? @map("tenant_id")
  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])
  role     Role    @relation(fields: [roleId], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  user     User    @relation(fields: [userId], references: [id])

  @@unique([userId, roleId, tenantId, branchId])
  @@map("user_roles")
}

model Branch {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  name            String
  address         String?
  phone           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  addressAr       String?           @map("address_ar")
  nameAr          String?           @map("name_ar")
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  carts           Cart[]
  cashSessions    CashSession[]
  deliveryTrips   DeliveryTrip[]
  drivers         Driver[]
  inventory       Inventory[]
  inventoryLedger InventoryLedger[]
  orders          Order[]
  pickLists       PickList[]
  purchaseOrders  PurchaseOrder[]
  refunds         Refund[]
  returns         Return[]
  revenueLedgers  RevenueLedger[]
  sales           Sale[]
  userRoles       UserRole[]
  vehicles        Vehicle[]
  zReports        ZReport[]

  @@unique([tenantId, name])
  @@map("branches")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  country   String?
  isOem     Boolean   @default(false) @map("is_oem")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  nameAr    String?   @map("name_ar")
  products  Product[]

  @@map("brands")
}

model ProductCategory {
  id        String            @id @default(uuid())
  name      String            @unique
  parentId  String?           @map("parent_id")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  nameAr    String?           @map("name_ar")
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryHierarchy")
  products  Product[]

  @@map("product_categories")
}

model Product {
  id                        String                     @id @default(uuid())
  brandId                   String                     @map("brand_id")
  categoryId                String                     @map("category_id")
  name                      String                     @unique
  description               String?
  weight                    Float?
  dimensions                String?
  status                    String                     @default("ACTIVE")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  taxRateId                 String?                    @map("tax_rate_id")
  images                    String[]
  unitOfMeasure             String?                    @default("EA") @map("unit_of_measure")
  descriptionAr             String?                    @map("description_ar")
  nameAr                    String?                    @map("name_ar")
  alternateNumbers          AlternatePartNumber[]
  cartItems                 CartItem[]
  inventory                 Inventory[]
  inventoryLedger           InventoryLedger[]
  invoiceLines              InvoiceLine[]
  orderItems                OrderItem[]
  packItems                 PackItem[]
  pickListItems             PickListItem[]
  fitments                  ProductFitment[]
  sources                   ProductSource[]
  suppliers                 ProductSupplier[]
  brand                     Brand                      @relation(fields: [brandId], references: [id])
  category                  ProductCategory            @relation(fields: [categoryId], references: [id])
  taxRate                   TaxRate?                   @relation(fields: [taxRateId], references: [id])
  purchaseOrderItems        PurchaseOrderItem[]
  purchaseOrderReceiptItems PurchaseOrderReceiptItem[]
  purchaseReturnItems       PurchaseReturnItem[]
  quoteItems                QuoteItem[]
  returnItems               ReturnItem[]
  saleItems                 SaleItem[]
  originalSubstitutions     Substitution[]             @relation("OriginalSub")
  newSubstitutions          Substitution[]             @relation("NewSub")

  @@map("products")
}

model Substitution {
  id                  String             @id @default(uuid())
  type                String             @default("INTERCHANGEABLE")
  confidenceScore     Decimal            @default(1.0) @map("confidence_score")
  source              String             @default("MANUAL")
  createdAt           DateTime           @default(now()) @map("created_at")
  orderId             String?            @map("order_id")
  orderItemId         String?            @map("order_item_id")
  originalProductId   String             @map("original_product_id")
  respondedAt         DateTime?          @map("responded_at")
  status              SubstitutionStatus @default(PENDING)
  substituteProductId String             @map("substitute_product_id")
  tenantId            String?            @map("tenant_id")
  order               Order?             @relation(fields: [orderId], references: [id])
  originalProduct     Product            @relation("OriginalSub", fields: [originalProductId], references: [id])
  substituteProduct   Product            @relation("NewSub", fields: [substituteProductId], references: [id])
  tenant              Tenant?            @relation(fields: [tenantId], references: [id])

  @@map("substitutions")
}

model VehicleMake {
  id        String         @id @default(uuid())
  name      String         @unique
  country   String?
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  models    VehicleModel[]

  @@map("vehicle_makes")
}

model VehicleModel {
  id         String           @id @default(uuid())
  makeId     String           @map("make_id")
  name       String
  yearStart  Int              @map("year_start")
  yearEnd    Int?             @map("year_end")
  engineType String?          @map("engine_type")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  fitments   ProductFitment[]
  make       VehicleMake      @relation(fields: [makeId], references: [id])

  @@unique([makeId, name, yearStart, engineType])
  @@index([makeId])
  @@map("vehicle_models")
}

model ProductFitment {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  vehicleModelId String       @map("vehicle_model_id")
  position       String?
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)

  @@unique([productId, vehicleModelId, position])
  @@index([productId])
  @@index([vehicleModelId])
  @@map("product_fitments")
}

model AlternatePartNumber {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  partNumber   String   @unique @map("part_number")
  manufacturer String?
  isSuperseded Boolean  @default(false) @map("is_superseded")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("alternate_part_numbers")
}

model DataSource {
  id             String          @id @default(uuid())
  name           String          @unique
  type           String
  url            String?
  lastSyncAt     DateTime?       @map("last_sync_at")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  productSources ProductSource[]

  @@map("data_sources")
}

model ProductSource {
  id           String     @id @default(uuid())
  productId    String     @map("product_id")
  dataSourceId String     @map("data_source_id")
  externalId   String?    @map("external_id")
  rawData      Json?      @map("raw_data")
  lastSyncedAt DateTime   @default(now()) @map("last_synced_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id])
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, dataSourceId])
  @@index([productId])
  @@index([dataSourceId])
  @@map("product_sources")
}

model Inventory {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  branchId      String    @map("branch_id")
  productId     String    @map("product_id")
  quantity      Int       @default(0)
  sellingPrice  Decimal   @map("selling_price") @db.Decimal(10, 2)
  barcode       String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  costPrice     Decimal   @default(0) @map("cost_price") @db.Decimal(10, 2)
  binLocation   String?   @map("bin_location")
  lastCountedAt DateTime? @map("last_counted_at")
  allocated     Int       @default(0)
  /// HC-3: Optimistic concurrency version
  version       Int       @default(0)
  branch        Branch    @relation(fields: [branchId], references: [id])
  product       Product   @relation(fields: [productId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([branchId, productId])
  @@map("inventory")
}

model Sale {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  branchId         String          @map("branch_id")
  customerName     String?         @map("customer_name")
  total            Decimal         @default(0) @db.Decimal(10, 2)
  status           String          @default("COMPLETED")
  cashSessionId    String?         @map("cash_session_id")
  refundedSaleId   String?         @map("refunded_sale_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  customerId       String?         @map("customer_id")
  businessClientId String?         @map("business_client_id")
  /// HC-3: Optimistic concurrency version
  version          Int             @default(0)
  voidReason       String?         @map("void_reason")
  baseAmount       Decimal         @default(0) @map("base_amount") @db.Decimal(10, 2)
  currency         String          @default("USD")
  exchangeRateUsed Decimal         @default(1.0) @map("exchange_rate_used") @db.Decimal(18, 6)
  invoice          Invoice?
  payments         Payment[]
  refunds          Refund[]
  returns          Return[]
  items            SaleItem[]
  branch           Branch          @relation(fields: [branchId], references: [id])
  businessClient   BusinessClient? @relation(fields: [businessClientId], references: [id])
  cashSession      CashSession?    @relation(fields: [cashSessionId], references: [id])
  customer         Customer?       @relation(fields: [customerId], references: [id])
  refundedSale     Sale?           @relation("RefundedSale", fields: [refundedSaleId], references: [id])
  refundSale       Sale[]          @relation("RefundedSale")
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  stripePayments   StripePayment[]

  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String   @map("sale_id")
  productId String   @map("product_id")
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id])
  sale      Sale     @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

model Payment {
  id                String         @id @default(uuid())
  tenantId          String         @map("tenant_id")
  saleId            String         @map("sale_id")
  sessionId         String?        @map("session_id")
  amount            Decimal        @db.Decimal(10, 2)
  method            PaymentMethod
  isRefund          Boolean        @default(false) @map("is_refund")
  refundedPaymentId String?        @unique @map("refunded_payment_id")
  reference         String?
  paidAt            DateTime       @default(now()) @map("paid_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  /// HC-3: Optimistic concurrency version
  version           Int            @default(0)
  baseAmount        Decimal        @default(0) @map("base_amount") @db.Decimal(10, 2)
  currency          String         @default("USD")
  exchangeRateUsed  Decimal        @default(1.0) @map("exchange_rate_used") @db.Decimal(18, 6)
  refundedPayment   Payment?       @relation("RefundedPayment", fields: [refundedPaymentId], references: [id])
  refundPayment     Payment?       @relation("RefundedPayment")
  sale              Sale           @relation(fields: [saleId], references: [id])
  session           CashSession?   @relation(fields: [sessionId], references: [id])
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  receipt           Receipt?
  stripe            StripePayment?

  @@index([tenantId])
  @@index([saleId])
  @@map("payments")
}

model CashSession {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  branchId       String          @map("branch_id")
  openedById     String          @map("opened_by_id")
  openedAt       DateTime        @default(now()) @map("opened_at")
  closedAt       DateTime?       @map("closed_at")
  closedByUserId String?         @map("closed_by_user_id")
  openingCash    Decimal         @map("opening_cash") @db.Decimal(10, 2)
  closingCash    Decimal?        @map("closing_cash") @db.Decimal(10, 2)
  expectedCash   Decimal?        @map("expected_cash") @db.Decimal(10, 2)
  difference     Decimal?        @map("difference") @db.Decimal(10, 2)
  status         String          @default("OPEN")
  /// HC-3: Optimistic concurrency version
  version        Int             @default(0)
  branch         Branch          @relation(fields: [branchId], references: [id])
  closedBy       User?           @relation("ClosedBy", fields: [closedByUserId], references: [id])
  openedBy       User            @relation("OpenedBy", fields: [openedById], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  payments       Payment[]
  refunds        Refund[]
  sales          Sale[]
  stripePayments StripePayment[]

  @@index([tenantId])
  @@index([branchId])
  @@map("cash_sessions")
}

model Invoice {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  saleId           String          @unique @map("sale_id")
  invoiceNumber    String          @map("invoice_number")
  amount           Decimal         @db.Decimal(10, 2)
  status           String          @default("UNPAID")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  issuedAt         DateTime        @default(now()) @map("issued_at")
  subtotal         Decimal         @default(0) @db.Decimal(10, 2)
  tax              Decimal         @default(0) @db.Decimal(10, 2)
  businessClientId String?         @map("business_client_id")
  /// HC-3: Optimistic concurrency version
  version          Int             @default(0)
  baseAmount       Decimal         @default(0) @map("base_amount") @db.Decimal(10, 2)
  currency         String          @default("USD")
  exchangeRateUsed Decimal         @default(1.0) @map("exchange_rate_used") @db.Decimal(18, 6)
  lines            InvoiceLine[]
  businessClient   BusinessClient? @relation(fields: [businessClientId], references: [id])
  sale             Sale            @relation(fields: [saleId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@map("invoices")
}

model Receipt {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  paymentId     String   @unique @map("payment_id")
  receiptNumber String   @map("receipt_number")
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  payment       Payment  @relation(fields: [paymentId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@map("receipts")
}

model Refund {
  id                  String             @id @default(uuid())
  tenantId            String             @map("tenant_id")
  branchId            String             @map("branch_id")
  saleId              String?            @map("sale_id")
  amount              Decimal            @db.Decimal(10, 2)
  reason              String
  cashSessionId       String?            @map("cash_session_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  cancelledAt         DateTime?          @map("cancelled_at")
  orderId             String?            @map("order_id")
  processedAt         DateTime?          @map("processed_at")
  refundNumber        String             @map("refund_number")
  returnId            String?            @unique @map("return_id")
  status              RefundStatus       @default(PENDING)
  cancelledById       String?            @map("cancelled_by_id")
  createdById         String             @map("created_by_id")
  deliveryExceptionId String?            @unique @map("delivery_exception_id")
  processedById       String?            @map("processed_by_id")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version             Int                @default(0)
  baseAmount          Decimal            @default(0) @map("base_amount") @db.Decimal(10, 2)
  currency            String             @default("USD")
  exchangeRateUsed    Decimal            @default(1.0) @map("exchange_rate_used") @db.Decimal(18, 6)
  items               RefundItem[]
  branch              Branch             @relation(fields: [branchId], references: [id])
  cancelledBy         User?              @relation("RefundCancelledBy", fields: [cancelledById], references: [id])
  cashSession         CashSession?       @relation(fields: [cashSessionId], references: [id])
  createdBy           User               @relation(fields: [createdById], references: [id])
  deliveryException   DeliveryException? @relation(fields: [deliveryExceptionId], references: [id])
  order               Order?             @relation(fields: [orderId], references: [id])
  processedBy         User?              @relation("RefundProcessedBy", fields: [processedById], references: [id])
  return              Return?            @relation(fields: [returnId], references: [id])
  sale                Sale?              @relation(fields: [saleId], references: [id])
  tenant              Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, refundNumber])
  @@index([tenantId])
  @@index([saleId])
  @@map("refunds")
}

model RefundItem {
  id          String    @id @default(uuid())
  refundId    String    @map("refund_id")
  orderItemId String    @map("order_item_id")
  quantity    Int
  amount      Decimal   @db.Decimal(10, 2)
  reason      String?
  createdAt   DateTime  @default(now()) @map("created_at")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  refund      Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId])
  @@index([orderItemId])
  @@map("refund_items")
}

model ZReport {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  branchId      String   @map("branch_id")
  businessDate  DateTime @map("business_date") @db.Date
  totalSales    Decimal  @map("total_sales") @db.Decimal(10, 2)
  totalReturns  Decimal  @map("total_returns") @db.Decimal(10, 2)
  totalPayments Decimal  @map("total_payments") @db.Decimal(10, 2)
  cashSales     Decimal  @map("cash_sales") @db.Decimal(10, 2)
  cardSales     Decimal  @map("card_sales") @db.Decimal(10, 2)
  transferSales Decimal  @map("transfer_sales") @db.Decimal(10, 2)
  openingCash   Decimal  @map("opening_cash") @db.Decimal(10, 2)
  expectedCash  Decimal  @map("expected_cash") @db.Decimal(10, 2)
  closingCash   Decimal  @map("closing_cash") @db.Decimal(10, 2)
  difference    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  branch        Branch   @relation(fields: [branchId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, branchId, businessDate])
  @@index([tenantId])
  @@map("z_reports")
}

model StripePayment {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id")
  saleId          String       @map("sale_id")
  paymentId       String?      @unique @map("payment_id")
  sessionId       String?      @map("session_id")
  paymentIntentId String       @unique @map("payment_intent_id")
  clientSecret    String       @map("client_secret")
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("usd")
  status          String       @default("PENDING")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version         Int          @default(0)
  payment         Payment?     @relation(fields: [paymentId], references: [id])
  sale            Sale         @relation(fields: [saleId], references: [id])
  session         CashSession? @relation(fields: [sessionId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("stripe_payments")
}

model PurchaseOrder {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  branchId     String                 @map("branch_id")
  supplierName String                 @map("supplier_name")
  status       PurchaseOrderStatus    @default(DRAFT)
  totalCost    Decimal                @default(0) @map("total_cost") @db.Decimal(10, 2)
  createdById  String                 @map("created_by_id")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  supplierId   String?                @map("supplier_id")
  currency     String                 @default("USD")
  exchangeRate Decimal                @default(1.0) @map("exchange_rate") @db.Decimal(18, 6)
  /// HC-3: Optimistic concurrency version
  version      Int                    @default(0)
  baseAmount   Decimal                @default(0) @map("base_amount") @db.Decimal(10, 2)
  items        PurchaseOrderItem[]
  receipts     PurchaseOrderReceipt[]
  branch       Branch                 @relation(fields: [branchId], references: [id])
  createdBy    User                   @relation(fields: [createdById], references: [id])
  supplier     Supplier?              @relation(fields: [supplierId], references: [id])
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  returns      PurchaseReturn[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  productId       String        @map("product_id")
  quantity        Int
  unitCost        Decimal       @map("unit_cost") @db.Decimal(10, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

model PurchaseOrderReceipt {
  id              String                     @id @default(uuid())
  tenantId        String                     @map("tenant_id")
  purchaseOrderId String                     @map("purchase_order_id")
  receiptNumber   String                     @map("receipt_number")
  receivedAt      DateTime                   @default(now()) @map("received_at")
  receivedById    String                     @map("received_by_id")
  notes           String?
  items           PurchaseOrderReceiptItem[]
  purchaseOrder   PurchaseOrder              @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_receipts")
}

model PurchaseOrderReceiptItem {
  id               String               @id @default(uuid())
  receiptId        String               @map("receipt_id")
  productId        String               @map("product_id")
  quantity         Int
  acceptedUnitCost Decimal              @map("accepted_unit_cost") @db.Decimal(10, 2)
  product          Product              @relation(fields: [productId], references: [id])
  receipt          PurchaseOrderReceipt @relation(fields: [receiptId], references: [id])

  @@map("purchase_order_receipt_items")
}

model ProductSupplier {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  productId   String   @map("product_id")
  supplierId  String   @map("supplier_id")
  supplierSku String?  @map("supplier_sku")
  costPrice   Decimal  @map("cost_price") @db.Decimal(10, 2)
  currency    String   @default("USD")
  isPreferred Boolean  @default(false) @map("is_preferred")
  product     Product  @relation(fields: [productId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, productId])
  @@map("product_suppliers")
}

model PurchaseReturn {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  purchaseOrderId String               @map("purchase_order_id")
  status          PurchaseReturnStatus @default(DRAFT)
  reason          String?
  rejectionReason String?              @map("rejection_reason")
  totalValue      Decimal              @default(0) @map("total_value") @db.Decimal(10, 2)
  createdById     String               @map("created_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version         Int                  @default(0)
  items           PurchaseReturnItem[]
  createdBy       User                 @relation(fields: [createdById], references: [id])
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  tenant          Tenant               @relation(fields: [tenantId], references: [id])

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String         @map("purchase_return_id")
  productId        String         @map("product_id")
  quantity         Int
  reason           String?
  createdAt        DateTime       @default(now()) @map("created_at")
  product          Product        @relation(fields: [productId], references: [id])
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])

  @@map("purchase_return_items")
}

model TaxRate {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  name         String
  percentage   Decimal       @db.Decimal(5, 2)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  nameAr       String?       @map("name_ar")
  invoiceLines InvoiceLine[]
  products     Product[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("tax_rates")
}

model Customer {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  phone     String?
  email     String?
  balance   Decimal    @default(0) @db.Decimal(10, 2)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version   Int        @default(0)
  nameAr    String?    @map("name_ar")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  sales     Sale[]
  tripStops TripStop[]

  @@index([tenantId])
  @@map("customers")
}

model Supplier {
  id             String            @id @default(uuid())
  tenantId       String            @map("tenant_id")
  name           String
  balance        Decimal           @default(0) @db.Decimal(10, 2)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version        Int               @default(0)
  nameAr         String?           @map("name_ar")
  products       ProductSupplier[]
  purchaseOrders PurchaseOrder[]
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  tripStops      TripStop[]

  @@index([tenantId])
  @@map("suppliers")
}

model InvoiceLine {
  id        String   @id @default(uuid())
  invoiceId String   @map("invoice_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  taxRateId String?  @map("tax_rate_id")
  taxAmount Decimal  @default(0) @map("tax_amount") @db.Decimal(10, 2)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  @@map("invoice_lines")
}

model ChartOfAccount {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  code          String
  name          String
  type          AccountType
  description   String?
  isSystem      Boolean       @default(false) @map("is_system")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version       Int           @default(0)
  descriptionAr String?       @map("description_ar")
  nameAr        String?       @map("name_ar")
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  journalLines  JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  reference   String           @unique
  date        DateTime         @db.Date
  description String?
  totalAmount Decimal          @map("total_amount") @db.Decimal(15, 2)
  status      String           @default("POSTED")
  createdAt   DateTime         @default(now()) @map("created_at")
  createdById String           @map("created_by_id")
  isPosted    Boolean          @default(false) @map("is_posted")
  postedAt    DateTime?        @map("posted_at")
  postedById  String?          @map("posted_by_id")
  reversesId  String?          @unique @map("reverses_id")
  event       AccountingEvent?
  createdBy   User             @relation("CreatedBy", fields: [createdById], references: [id])
  postedBy    User?            @relation("PostedBy", fields: [postedById], references: [id])
  reverses    JournalEntry?    @relation("Reversals", fields: [reversesId], references: [id])
  reversedBy  JournalEntry?    @relation("Reversals")
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  lines       JournalLine[]

  @@index([tenantId])
  @@index([date])
  @@index([isPosted])
  @@map("journal_entries")
}

model JournalLine {
  id             String         @id @default(uuid())
  journalEntryId String         @map("journal_entry_id")
  accountId      String         @map("account_id")
  description    String?
  debit          Decimal        @default(0) @db.Decimal(15, 2)
  credit         Decimal        @default(0) @db.Decimal(15, 2)
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id])

  @@map("journal_lines")
}

model AccountingEvent {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  eventType      String
  eventSourceId  String       @map("event_source_id")
  journalEntryId String       @unique @map("journal_entry_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventSourceId])
  @@map("accounting_events")
}

model AccountingPeriod {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  isClosed   Boolean   @default(false) @map("is_closed")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  closedAt   DateTime? @map("closed_at")
  closedById String?   @map("closed_by_id")
  closedBy   User?     @relation("ClosedBy", fields: [closedById], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([isClosed])
  @@map("accounting_periods")
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  userId        String   @map("user_id")
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  oldValue      Json?    @map("old_value")
  newValue      Json?    @map("new_value")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")
  correlationId String?  @map("correlation_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model BusinessClient {
  id                 String                  @id @default(uuid())
  tenantId           String                  @map("tenant_id")
  type               BusinessClientType
  businessName       String                  @map("business_name")
  registrationNumber String?                 @map("registration_number")
  taxId              String?                 @map("tax_id")
  primaryEmail       String?                 @map("primary_email")
  primaryPhone       String?                 @map("primary_phone")
  creditLimit        Decimal                 @default(0) @map("credit_limit") @db.Decimal(12, 2)
  currentBalance     Decimal                 @default(0) @map("current_balance") @db.Decimal(12, 2)
  paymentTermsDays   Int                     @default(0) @map("payment_terms_days")
  status             String                  @default("ACTIVE")
  notes              String?
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  currency           String                  @default("USD")
  paymentTerms       String?                 @map("payment_terms")
  priceTierId        String?                 @map("price_tier_id")
  addresses          BusinessClientAddress[]
  contacts           BusinessClientContact[]
  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  carts              Cart[]
  invoices           Invoice[]
  orders             Order[]
  priceRules         PriceRule[]
  quotes             Quote[]
  sales              Sale[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("business_clients")
}

model PriceRule {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  name             String
  type             PriceRuleType
  value            Decimal         @db.Decimal(10, 2)
  priority         Int             @default(0)
  minQuantity      Int             @default(1) @map("min_quantity")
  brandId          String?         @map("brand_id")
  categoryId       String?         @map("category_id")
  productId        String?         @map("product_id")
  businessClientId String?         @map("business_client_id")
  priceTierId      String?         @map("price_tier_id")
  startDate        DateTime?       @map("start_date")
  endDate          DateTime?       @map("end_date")
  isActive         Boolean         @default(true) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  businessClient   BusinessClient? @relation(fields: [businessClientId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("price_rules")
}

model Quote {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  quoteNumber      String          @unique @map("quote_number")
  businessClientId String?         @map("business_client_id")
  customerName     String?         @map("customer_name")
  subtotal         Decimal         @db.Decimal(12, 2)
  tax              Decimal         @default(0) @db.Decimal(12, 2)
  total            Decimal         @db.Decimal(12, 2)
  status           QuoteStatus     @default(DRAFT)
  validUntil       DateTime?       @map("valid_until")
  sentAt           DateTime?       @map("sent_at")
  rejectionReason  String?         @map("rejection_reason")
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version          Int             @default(0)
  createdById      String?         @map("created_by_id")
  items            QuoteItem[]
  businessClient   BusinessClient? @relation(fields: [businessClientId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("quotes")
}

model QuoteItem {
  id        String  @id @default(uuid())
  quoteId   String  @map("quote_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  lineTotal Decimal @default(0) @map("line_total") @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id])
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

model BusinessClientContact {
  id               String         @id @default(uuid())
  businessClientId String         @map("business_client_id")
  name             String
  position         String?
  email            String?
  phone            String?
  isPrimary        Boolean        @default(false) @map("is_primary")
  canPlaceOrders   Boolean        @default(true) @map("can_place_orders")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  businessClient   BusinessClient @relation(fields: [businessClientId], references: [id], onDelete: Cascade)
  orders           Order[]

  @@index([businessClientId])
  @@map("business_client_contacts")
}

model BusinessClientAddress {
  id               String         @id @default(uuid())
  businessClientId String         @map("business_client_id")
  type             String
  addressLine1     String         @map("address_line1")
  addressLine2     String?        @map("address_line2")
  city             String
  state            String?
  postalCode       String?        @map("postal_code")
  country          String         @default("Egypt")
  isPrimary        Boolean        @default(false) @map("is_primary")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  businessClient   BusinessClient @relation(fields: [businessClientId], references: [id], onDelete: Cascade)
  orders           Order[]

  @@index([businessClientId])
  @@map("business_client_addresses")
}

model Order {
  id                  String                 @id @default(uuid())
  tenantId            String                 @map("tenant_id")
  businessClientId    String                 @map("business_client_id")
  branchId            String                 @map("branch_id")
  orderNumber         String                 @map("order_number")
  deliveryAddressId   String?                @map("delivery_address_id")
  contactId           String?                @map("contact_id")
  subtotal            Decimal                @db.Decimal(12, 2)
  tax                 Decimal                @default(0) @db.Decimal(12, 2)
  total               Decimal                @db.Decimal(12, 2)
  status              OrderStatus            @default(PENDING)
  notes               String?
  internalNotes       String?                @map("internal_notes")
  confirmedAt         DateTime?              @map("confirmed_at")
  shippedAt           DateTime?              @map("shipped_at")
  deliveredAt         DateTime?              @map("delivered_at")
  cancelledAt         DateTime?              @map("cancelled_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  createdById         String?                @map("created_by_id")
  deliveryExceptionId String?                @unique @map("delivery_exception_id")
  returnId            String?                @unique @map("return_id")
  sourceQuoteId       String?                @map("source_quote_id")
  /// HC-3: Optimistic concurrency version. Increment on every mutation.
  version             Int                    @default(0)
  chargebacks         Chargeback[]
  items               OrderItem[]
  branch              Branch                 @relation(fields: [branchId], references: [id])
  businessClient      BusinessClient         @relation(fields: [businessClientId], references: [id])
  contact             BusinessClientContact? @relation(fields: [contactId], references: [id])
  deliveryAddress     BusinessClientAddress? @relation(fields: [deliveryAddressId], references: [id])
  deliveryException   DeliveryException?     @relation("ReplacementSource", fields: [deliveryExceptionId], references: [id])
