  totalRevenue Decimal         @default(0) @map("total_revenue") @db.Decimal(12, 2)
  status       TaxFilingStatus @default(DRAFT)
  filedAt      DateTime?       @map("filed_at")
  filedById    String?         @map("filed_by_id")
  reportData   Json?           @map("report_data")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version      Int             @default(0)
  tenant       Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([status])
  @@map("tax_filings")
}

model ShipmentManifest {
  id           String          @id @default(uuid())
  tenantId     String          @map("tenant_id")
  branchId     String          @map("branch_id")
  manifestRef  String          @map("manifest_ref")
  tripId       String?         @map("trip_id")
  status       ManifestStatus  @default(DRAFT)
  sealedAt     DateTime?       @map("sealed_at")
  dispatchedAt DateTime?       @map("dispatched_at")
  completedAt  DateTime?       @map("completed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  /// HC-3: Optimistic concurrency version
  version      Int             @default(0)
  orders       ManifestOrder[]
  tenant       Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, manifestRef])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@map("shipment_manifests")
}

model ManifestOrder {
  id                 String           @id @default(uuid())
  shipmentManifestId String           @map("shipment_manifest_id")
  orderId            String           @map("order_id")
  sequence           Int              @default(0)
  createdAt          DateTime         @default(now()) @map("created_at")
  shipmentManifest   ShipmentManifest @relation(fields: [shipmentManifestId], references: [id], onDelete: Cascade)

  @@unique([shipmentManifestId, orderId])
  @@index([shipmentManifestId])
  @@index([orderId])
  @@map("manifest_orders")
}

